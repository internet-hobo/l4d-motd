<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>L4D Host Banner</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #000000;
      color: #ff0000;
      font-family: Impact, Arial, sans-serif;
    }

    .banner {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #200000;
      border-bottom: 3px solid #ff0000;
      font-size: 26px;              /* big block banner text */
      text-transform: uppercase;
      letter-spacing: 3px;
    }
  </style>
</head>
<body>
  <div class="banner">
    Red & Black Co-op Server
  </div>
</body>
</html>
